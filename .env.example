# ============================================================
# QMS AI Assistant — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# --- SITE ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=QMS Assistant
NEXT_PUBLIC_SITE_TITLE="QMS AI Assistant — Intelligent Document Management"
NEXT_PUBLIC_SITE_DESCRIPTION="Multimodal AI assistant for Quality Management Systems"
NEXT_PUBLIC_DEFAULT_THEME_MODE=light

# --- AUTH ---
NEXT_PUBLIC_AUTH_PASSWORD=true
NEXT_PUBLIC_AUTH_MAGIC_LINK=false

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- DEPLOYMENT MODE ---
# Controls whether the app uses local (Ollama) or cloud (API) for LLM and embeddings.
# Values: local | cloud
DEPLOYMENT_MODE=local

# --- OLLAMA (mode local) ---
# Base URL of the Ollama server (local inference)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# LLM model to use for chat completions (e.g. llama3, mistral)
OLLAMA_LLM_MODEL=llama3
# Embedding model to use for vectorization (e.g. nomic-embed-text, mxbai-embed-large)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- CLOUD LLM (mode cloud) ---
# Provider: openai | anthropic
CLOUD_LLM_PROVIDER=openai
# API key for the cloud LLM provider (NEVER commit a real key)
CLOUD_LLM_API_KEY=your-cloud-llm-api-key-here

# --- LOCALES ---
NEXT_PUBLIC_LOCALES_PATH=apps/web/public/locales
NEXT_PUBLIC_LANGUAGE_PRIORITY=application

# --- FEATURE FLAGS ---
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true
NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_DELETION=true

# --- WHISPER / SPEECH-TO-TEXT (Phase 6 — Multimodal) ---
# Local Whisper endpoint (e.g. faster-whisper-server, whisper.cpp server)
# Only needed if DEPLOYMENT_MODE=local and you want voice transcription
WHISPER_LOCAL_URL=http://127.0.0.1:9000/asr

# --- SHAREPOINT INTEGRATION (Phase 6 — Connecteur) ---
# Microsoft Entra (Azure AD) tenant and application credentials
SHAREPOINT_TENANT_ID=your-tenant-id-here
SHAREPOINT_CLIENT_ID=your-client-id-here
SHAREPOINT_CLIENT_SECRET=your-client-secret-here
# SharePoint site ID (can be found via Graph Explorer: /sites/{hostname}:/{path})
SHAREPOINT_SITE_ID=your-site-id-here
# Drive ID of the document library to sync (found via /sites/{siteId}/drives)
SHAREPOINT_DRIVE_ID=your-drive-id-here
# Optional: JSON mapping of SharePoint roles → criticality levels
# Default: {"low":["read","viewer"],"medium":["write","contribute","contributor","member"],"high":["owner","full control","admin"]}
# SHAREPOINT_CRITICALITY_MAP={"low":["read"],"medium":["write"],"high":["owner"]}
